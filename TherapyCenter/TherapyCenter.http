
# SEEDED CREDENTIALS:
#   admin@therapy.com        →  Admin@123
#   priya.doctor@therapy.com →  Doctor@123
#   reception@therapy.com    →  Reception@123
#   ramesh@therapy.com       →  Guardian@123
#   patient@therapy.com      →  Patient@123
# =============================================================

# @host = https://localhost:7226

# =============================================================
# PHASE 1 — LOGIN
# =============================================================

@env=dev
@host = https://localhost:7226
### Login as Admin
POST  https://localhost:7226/api/auth/login
Content-Type: application/json

{
  "email": "admin@therapy.com",
  "password": "Admin@123"
}

### Login as Doctor
@host = https://localhost:7226
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "priya.doctor@therapy.com",
  "password": "Doctor@123"
}

### Login as Receptionist
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "reception@therapy.com",
  "password": "Reception@123"
}

### Login as Guardian
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "ramesh@therapy.com",
  "password": "Guardian@123"
}

### Login as Patient
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "patient@therapy.com",
  "password": "Patient@123"
}


